    {
      "id": 11,
      "type": "table",
      "title": "Last 50 frames",
      "description": "Most recent 50 MQTT frames received from the device (telemetry + alerts), independent of the dashboard time range.",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"telemetry\")\n |> range(start: -30d)\n |> filter(fn: (r) => (r._measurement == \"telemetry\" or r._measurement == \"alert\") and r.device == \"${device}\")\n |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n |> group()\n |> sort(columns: [\"_time\"], desc: true)\n |> limit(n: 50)\n |> keep(columns: [\"_time\",\"_measurement\",\"kind\",\"wake\",\"t_cab\",\"t_amb\",\"door\",\"ext_power\",\"alarm\",\"vbat_mv\",\"vsolar_mv\",\"rssi_dbm\",\"lat\",\"lon\",\"boot\",\"buffered\",\"powered\",\"fw\"])"
