  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cabinet temperature",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 5,
        "h": 5
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"telemetry\")\n |> range(start: -1h)\n |> filter(fn: (r) => r._measurement == \"telemetry\" and r.device == \"${device}\" and r._field == \"t_cab\")\n |> last()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
