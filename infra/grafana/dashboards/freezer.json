    {
      "id": 6,
      "type": "timeseries",
      "title": "Temperature",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 9
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"telemetry\")\n |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n |> filter(fn: (r) => r._measurement == \"telemetry\" and r.device == \"${device}\")\n |> filter(fn: (r) => r._field == \"t_cab\" or r._field == \"t_amb\")\n |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "t_cab"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#4E79A7"
                }
              },
              {
                "id": "displayName",
                "value": "Cabinet"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "t_amb"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F28E2B"
                }
              },
              {
                "id": "displayName",
                "value": "Ambient"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
