# freezerMon platform secrets — copy to .env and fill in. Never commit .env.
# Generate strong values, e.g.:  openssl rand -hex 24

# InfluxDB
INFLUX_PASSWORD=
INFLUX_TOKEN=
INFLUX_ORG=freezermon
INFLUX_BUCKET=telemetry

# MQTT credentials the devices AND Telegraf use (created via mosquitto_passwd, see README)
MQTT_USER=freezer
MQTT_PASSWORD=

# Grafana logins: admin (full control) + operator (read-only viewer)
GRAFANA_ADMIN_PASSWORD=
GRAFANA_OPERATOR_PASSWORD=
# GRAFANA_PORT=3000   # host port for the Grafana UI (default 3000)

# Not used by the stack — recorded here so the device's WiFi debug-console
# password (DEBUG_AP_PASSWORD in firmware config.h) is findable later.
DEVICE_DEBUG_AP_PASSWORD=
